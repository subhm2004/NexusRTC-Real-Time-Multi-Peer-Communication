# =============================================================================
# NexusRTC — Environment variables
# Copy:  cp .env.example .env
# Local dev: TURN + Sentry can stay empty. Production: set TURN (required for NAT).
# =============================================================================

# --- Server (usually no change) ---
PORT=3000
NODE_ENV=development
HOSTNAME=0.0.0.0

# --- TURN (production / strict WiFi) ---
# Without TURN, calls work on same network or simple home WiFi only.
# Corporate WiFi / mobile data often need TURN.
#
# Option A — Metered Open Relay (free tier, quick start):
#   https://www.metered.ca/tools/openrelay/
#   Sign up → Dashboard → get URL, username, password
#
# Option B — Twilio Network Traversal:
#   https://www.twilio.com/docs/stun-turn
#
# Option C — Self-host coturn on a VPS (DigitalOcean, Hetzner, etc.)
#
# Format examples:
#   TURN_URL=turn:openrelay.metered.ca:80
#   TURN_URL=turn:your-vps-ip:3478
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# --- Sessions & rooms ---
# SESSION_TTL_MS = how long join token works (ms). Default 24h.
SESSION_TTL_MS=86400000
# ROOM_IDLE_TTL_MS = delete empty room after idle (ms). Default 24h.
ROOM_IDLE_TTL_MS=86400000
# MAX_PEERS = max people in one call (mesh — keep 4–6).
MAX_PEERS=6

# --- Recordings ---
# Max upload size per recording (MB). Needs disk space on server.
MAX_RECORDING_MB=200

# --- Error monitoring (optional) ---
# Sentry: https://sentry.io → Create project (Browser/Next.js) → Settings → DSN
NEXT_PUBLIC_SENTRY_DSN=
